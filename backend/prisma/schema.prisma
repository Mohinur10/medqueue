generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  firstName String?
  lastName  String?
  role      String      @default("PATIENT")
  phone     String?     @unique
  language  String      @default("uz")
  passport  String?
  birthday  DateTime?
  gender    String?
  address   String?
  avatar    String?
  isActive  Boolean   @default(true)
  isEmailVerified Boolean @default(false)
  accountLocked Boolean @default(false)
  failedLoginAttempts Int @default(0)
  lockUntil DateTime?
  telegramId String? @unique
  telegramUsername String?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  patient       Patient?
  doctor        Doctor?
  managedHospitals Hospital[] @relation("HospitalDirector")
  refreshTokens RefreshToken[]
  verificationTokens VerificationToken[]
  logs          AuditLog[]
  announcements Announcement[] @relation("UserAnnouncements")
}

model Hospital {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  logo        String?
  address     String?
  region      String?
  district    String?
  phone       String?
  email       String?
  website     String?
  workingHours String?
  emergencyAvailable Boolean @default(false)
  isActive    Boolean @default(true)
  latitude    Float?
  longitude   Float?
  
  directorId  String?
  director    User?     @relation("HospitalDirector", fields: [directorId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  departments Department[]
  doctors     Doctor[]
  announcements Announcement[]
}

model Department {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  floor       String?
  roomNumber  String?
  phone       String?
  isActive    Boolean  @default(true)
  hospitalId  String

  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctors     Doctor[]
  queues      Queue[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model Doctor {
  id             String   @id @default(uuid())
  slug           String   @unique
  userId         String   @unique
  hospitalId     String
  departmentId   String
  specialization String
  experienceYears Int?
  education      String?
  languages      String
  biography      String?
  consultationFee Float?
  licenseNumber  String?
  isAvailable    Boolean  @default(true)
  isActive       Boolean  @default(true)
  maxPatients    Int      @default(20)
  isOnline       Boolean  @default(false)

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital       Hospital   @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  
  certificates   DoctorCertificate[]
  schedules      Schedule[]
  appointments   Appointment[]
  queues         Queue[]
  records        MedicalRecord[]
  prescriptions  Prescription[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model DoctorCertificate {
  id          String   @id @default(uuid())
  doctorId    String
  fileUrl     String
  title       String
  issuer      String
  issuedAt    DateTime?
  expiresAt   DateTime?
  
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Patient {
  id         String   @id @default(uuid())
  userId     String   @unique
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family     FamilyMember[]
  appointments Appointment[]
  records    MedicalRecord[]
  prescriptions Prescription[]
  payments   Payment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
}

model FamilyMember {
  id         String   @id @default(uuid())
  patientId  String
  name       String
  relation   String
  birthday   DateTime?
  gender     String?

  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
}

model Schedule {
  id          String   @id @default(uuid())
  doctorId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  breakStart  String?
  breakEnd    String?
  isVacation  Boolean  @default(false)

  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id         String            @id @default(uuid())
  patientId  String
  doctorId   String
  date       DateTime
  status     String @default("PENDING")
  notes      String?

  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  queue      Queue?
  transaction Transaction?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
}

model Queue {
  id             String      @id @default(uuid())
  departmentId   String
  doctorId       String
  appointmentId  String      @unique
  number         Int
  status         String @default("WAITING")
  estimatedTime  DateTime?
  isPriority     Boolean     @default(false)

  department     Department  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  doctor         Doctor      @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  @@index([departmentId, status])
  @@index([doctorId, status])
}

model MedicalRecord {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String
  diagnosis       String
  analysis        String?
  recommendations String?

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  prescriptions   Prescription[]
  files           File[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
}

model Prescription {
  id              String        @id @default(uuid())
  recordId        String
  doctorId        String
  patientId       String
  fileUrl         String?

  record          MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  doctor          Doctor        @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
}

model Payment {
  id            String        @id @default(uuid())
  patientId     String
  amount        Float
  status        String @default("PENDING")
  method        String
  
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  transactions  Transaction[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
}

model Transaction {
  id            String   @id @default(uuid())
  paymentId     String
  appointmentId String?  @unique
  providerTxId  String?  @unique
  amount        Float
  currency      String   @default("UZS")
  status        String

  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String

  createdAt DateTime @default(now())
}

model File {
  id        String   @id @default(uuid())
  recordId  String?
  url       String
  type      String

  record    MedicalRecord? @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  deviceName String?
  deviceId   String?
  ipAddress  String?
  userAgent  String?
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  revokedAt DateTime?
  lastUsedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  type      String
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  authorId  String
  hospitalId String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  
  author    User     @relation("UserAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)
  hospital  Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
